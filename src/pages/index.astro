---
import "../styles/global.css";
import { capabilities, domains, entries, openDomainIds, totalSeats } from "../data/team";

const openDomains = domains.filter((domain) => openDomainIds.has(domain.id));
const filters = [{ id: "all", label: "全部" }, ...openDomains];
const tones = ["blue", "coral", "dark", "pale", "blue", "coral"];
const pad = (n: number) => String(n).padStart(2, "0");
const domainLabel = Object.fromEntries(domains.map((d) => [d.id, d.label]));
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "AIRDB Team",
  url: "https://airdb.team/",
  email: "info@airdb.com",
  founder: {
    "@type": "Person",
    name: "阿正_Dean",
    alternateName: "Dean",
    jobTitle: "Founder",
    knowsAbout: ["Cybersecurity", "AI Systems", "Infrastructure"],
  },
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="AIRDB Team 是由独立公司、前沿技术人才与专业能力组成的全球协作网络。" />
    <meta name="theme-color" content="#ffffff" />
    <title>AIRDB Team — 前沿技术人才与独立公司网络</title>
    <link rel="canonical" href="https://airdb.team/" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://airdb.team/" />
    <meta property="og:title" content="AIRDB Team — 前沿技术人才与独立公司网络" />
    <meta property="og:description" content="AIRDB Team 是由独立公司、前沿技术人才与专业能力组成的全球协作网络。" />
    <meta property="og:site_name" content="AIRDB Team" />
    <meta property="og:image" content="https://airdb.team/images/og-card.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="AIRDB Team — 前沿技术人才与独立公司网络" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preload" href="/fonts/ibm-plex-mono-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.json" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#people">跳到成员目录</a>
    <header class="site-header">
      <a class="brand" href="#top" aria-label="AIRDB Team 首页">
        <strong>AIRDB</strong><span>/</span><em>TEAM</em>
      </a>
      <details class="site-nav">
        <summary aria-label="打开导航菜单"><span class="menu-icon" aria-hidden="true"></span></summary>
        <nav aria-label="主导航">
          <a href="#network">网络</a>
          <a href="#people">成员</a>
          <a href="#capabilities">方向</a>
          <a href="#about">关于</a>
          <a class="nav-cta" href="#people">浏览成员 <span aria-hidden="true">↘</span></a>
        </nav>
      </details>
    </header>

    <main id="top">
      <section class="hero" id="network">
        <div class="hero-copy">
          <h1><span>汇聚独立</span><span>公司，</span><span>协作成为</span><span>一体。</span></h1>
          <p>AIRDB Team 将独立创造者、技术专家与创始人公司连接成一个可信赖的全球前沿技术网络。</p>
          <div class="hero-actions">
            <a class="button button-primary" href="#people">探索团队网络 <span aria-hidden="true">→</span></a>
            <a class="button button-quiet" href="#about">了解协作方式 <span aria-hidden="true">↘</span></a>
          </div>
          <dl class="hero-stats">
            <div><dt>01</dt><dd>创始人已就位</dd></div>
            <div><dt>{totalSeats}</dt><dd>首批开放席位</dd></div>
            <div><dt>18</dt><dd>规划技术领域</dd></div>
          </dl>
          <p class="hero-note">网络正在组建第一批成员。以上为真实开放席位，非既有规模。</p>
        </div>

        <div class="network-map cell-map" aria-label="AIRDB Team 细胞式能力网络示意图">
          <svg class="cell-field" viewBox="0 0 760 650" aria-hidden="true">
            <defs>
              <radialGradient id="cell-blue" cx="42%" cy="38%" r="70%">
                <stop offset="0" stop-color="#eef2ff" />
                <stop offset="1" stop-color="#ffffff" />
              </radialGradient>
              <radialGradient id="cell-coral" cx="45%" cy="42%" r="70%">
                <stop offset="0" stop-color="#fff1ed" />
                <stop offset="1" stop-color="#ffffff" />
              </radialGradient>
            </defs>
            <g class="cell-membranes">
              <path class="cell cell-1" d="M43 180C42 105 101 48 177 50c75 2 123 61 118 135-4 58-48 103-104 115-72 16-147-43-148-120Z" />
              <path class="cell cell-2" d="M282 134c23-64 93-103 159-78 67 25 95 101 66 164-25 54-88 82-145 63-65-22-105-81-80-149Z" />
              <path class="cell cell-3 cell-warm" d="M205 303c9-72 72-119 143-112 74 7 124 70 113 143-9 63-65 108-128 106-73-3-137-64-128-137Z" />
              <path class="cell cell-4" d="M483 246c34-59 111-80 170-43 58 37 73 114 35 170-34 51-103 68-157 38-64-35-83-103-48-165Z" />
              <path class="cell cell-5" d="M54 420c18-68 87-110 155-88 66 21 102 92 78 157-21 58-84 93-145 78-70-18-107-78-88-147Z" />
              <path class="cell cell-6 cell-warm" d="M293 465c17-70 88-111 157-91 70 21 107 94 82 162-22 61-88 93-150 75-68-20-107-78-89-146Z" />
            </g>
            <g class="cell-nuclei">
              <circle cx="167" cy="170" r="39" /><circle cx="167" cy="170" r="26" />
              <circle cx="402" cy="159" r="34" /><circle cx="402" cy="159" r="21" />
              <circle cx="330" cy="321" r="43" /><circle cx="330" cy="321" r="27" />
              <circle cx="587" cy="305" r="38" /><circle cx="587" cy="305" r="23" />
              <circle cx="169" cy="461" r="36" /><circle cx="169" cy="461" r="22" />
              <circle cx="413" cy="502" r="40" /><circle cx="413" cy="502" r="25" />
            </g>
            <g class="cell-vesicles">
              <circle cx="90" cy="126" r="6" /><circle cx="232" cy="232" r="4" /><circle cx="340" cy="92" r="5" />
              <circle cx="468" cy="234" r="7" /><circle cx="632" cy="218" r="5" /><circle cx="667" cy="344" r="3" />
              <circle cx="101" cy="486" r="4" /><circle cx="238" cy="387" r="6" /><circle cx="361" cy="562" r="5" />
              <circle cx="492" cy="455" r="4" /><circle cx="535" cy="525" r="7" /><circle cx="704" cy="283" r="4" />
            </g>
          </svg>
          <button class="map-node node-ai" data-jump="ai"><span>VECTOR</span><strong>人工智能</strong></button>
          <button class="map-node node-aero" data-jump="aero"><span>ORBITAL</span><strong>航空航天</strong></button>
          <button class="map-node node-bio" data-jump="bio"><span>HELIX</span><strong>生物科技</strong></button>
          <button class="map-node node-ocean" data-jump="ocean"><span>PELAGIC</span><strong>航海科技</strong></button>
          <button class="map-node node-materials" data-jump="materials"><span>LATTICE</span><strong>先进材料</strong></button>
          <button class="map-node node-health" data-jump="health"><span>CLINICA</span><strong>医疗健康</strong></button>
          <div class="map-index"><span>LIVING CAPABILITY NETWORK</span><b>06 / 18</b></div>
          <div class="cell-domain-ticker" aria-label="规划中的 18 个前沿技术领域">
            <div class="domain-track">
              {[...domains, ...domains].map((domain, index) => {
                const duplicate = index >= domains.length;
                const num = pad((index % domains.length) + 1);
                return openDomainIds.has(domain.id) ? (
                  <button type="button" class="domain-open" data-jump={domain.id} aria-hidden={duplicate ? "true" : undefined} tabindex={duplicate ? "-1" : undefined}>
                    <i>{num}</i>{domain.label}
                  </button>
                ) : (
                  <span class="domain-planned" aria-hidden={duplicate ? "true" : undefined}><i>{num}</i>{domain.label}</span>
                );
              })}
            </div>
          </div>
        </div>
      </section>

      <section class="intro-strip">
        <h2>一张由独立公司组成的<br />全球技术能力地图</h2>
        <p>每个节点都保持独立，基于共同标准进行跨学科协作。这里展示的不是层级，而是可以被发现、组合与信任的专业能力。</p>
        <a href="#capabilities">查看能力分布 <span aria-hidden="true">→</span></a>
      </section>

      <section class="people-section" id="people">
        <div class="section-header">
          <div><span class="section-number">01</span><h2>认识网络中的人</h2></div>
          <p>创始人已就位，首批席位正在开放。OPC 指独立经营的一人公司（One-Person Company）。</p>
        </div>
        <div class="directory-tools">
          <label class="member-search" for="member-search">
            <span>搜索成员、公司或专长</span>
            <input id="member-search" type="search" placeholder="输入关键词" autocomplete="off" />
          </label>
          <p class="result-count" aria-live="polite">{entries.length} / {entries.length} 项</p>
        </div>
        <div class="filters" role="group" aria-label="按技术领域筛选">
          {filters.map((field, index) => (
            <button type="button" class:list={[index === 0 && "active"]} data-filter={field.id} aria-pressed={index === 0 ? "true" : "false"}>{field.label}</button>
          ))}
        </div>
        <div class="member-grid" aria-live="polite">
          {entries.map((entry, index) => (
            entry.kind === "founder" ? (
              <article
                class="member member-founder"
                data-field={entry.field}
                data-index={index}
                data-search={`${entry.name} ${entry.company} ${entry.role} ${entry.place} ${entry.focus} ${entry.handle} ${entry.tags.join(" ")} founder 创始人`.toLowerCase()}
              >
                <button class="member-open founder-open" aria-label={`查看创始人 ${entry.name} 的详细资料`}>
                  <span class="founder-portrait portrait p0" aria-hidden="true"></span>
                  <span class="founder-body">
                    <span class="founder-topline"><b>{entry.company} · FOUNDER</b><span class="founder-signal" aria-hidden="true"></span><i>00</i></span>
                    <span class="founder-name">{entry.name}<em class="founder-caret" aria-hidden="true"></em></span>
                    <span class="founder-role">{entry.role}</span>
                    <span class="founder-terminal" aria-hidden="true">
                      {entry.terminal.map((line, lineIndex) => (
                        <span class="t-line" style={`--t:${lineIndex}`}>
                          <i>$ {line.cmd}</i>
                          <b>{line.out}</b>
                        </span>
                      ))}
                    </span>
                    <span class="founder-tags">{entry.tags.map((tag) => <span>{tag}</span>)}</span>
                    <span class="founder-meta"><span>{entry.place}</span><span>{entry.focus}</span></span>
                  </span>
                  <span class="member-arrow" aria-hidden="true">↗</span>
                </button>
              </article>
            ) : (
              <article
                class="member member-opening"
                data-field={entry.field}
                data-index={index}
                data-search={`${entry.seat} ${domainLabel[entry.field]} ${entry.focus} ${entry.place} ${entry.status} 招募 opening 席位`.toLowerCase()}
              >
                <button class="member-open opening-open" aria-label={`了解招募位：${entry.seat}`}>
                  <span class="opening-body">
                    <span class="member-topline"><b>{domainLabel[entry.field]} · 招募位</b><i>{pad(index)}</i></span>
                    <span class="opening-seat">{entry.seat}</span>
                    <span class="opening-status"><span class="opening-dot" aria-hidden="true"></span>{entry.status}</span>
                    <span class="member-meta"><span>{entry.place}</span><span>{entry.focus}</span></span>
                  </span>
                  <span class="member-arrow" aria-hidden="true">↗</span>
                </button>
              </article>
            )
          ))}
        </div>
        <div class="empty-state" hidden>
          <span>NO OPEN SEAT</span>
          <h3>这个领域还没有开放席位。</h3>
          <p>它已在规划版图中。你可以浏览正在招募的领域，或直接来信提出你的方向。</p>
          <button type="button" data-reset-directory>查看全部开放席位</button>
        </div>
        <p class="sample-note">创始人为真实成员；招募位为真实开放席位，尚未有人入驻。</p>
      </section>

      <section class="capability-section" id="capabilities">
        <div class="section-header capability-heading">
          <div><span class="section-number">02</span><h2>首批优先开放的方向</h2></div>
          <p>从计算到生命科学，从天空到深海。条形代表首批投入优先级，右侧为已招募 / 目标席位。</p>
        </div>
        <div class="capability-bars">
          {capabilities.map((item, index) => (
            <button type="button" class={`capability-row ${tones[index]}`} data-jump={item.id}>
              <span class="capability-index">{pad(index + 1)}</span>
              <strong>{item.label}</strong>
              <span>{item.en}</span>
              <i style={`--size:${item.weight}%`}></i>
              <b>0 / {item.seats}</b>
            </button>
          ))}
        </div>
      </section>

      <section class="about-section" id="about">
        <div class="about-manifesto">
          <span>OUR OPERATING MODEL</span>
          <h2>保持独立。<br />共享标准。<br /><em>共同抵达更远。</em></h2>
        </div>
        <div class="about-copy">
          <p>AIRDB Team 不是传统的人员编制，而是一套面向独立公司的协作基础设施。每个成员可以专注于最擅长的领域，同时获得跨学科项目、知识网络与集团能力的支持。</p>
          <ol>
            <li><span>01</span><div><strong>独立经营</strong><p>每个 OPC 保持自己的专业方向、节奏与判断。</p></div></li>
            <li><span>02</span><div><strong>可信连接</strong><p>用清晰档案、能力标签与共同标准降低协作成本。</p></div></li>
            <li><span>03</span><div><strong>动态组队</strong><p>围绕复杂任务，把不同领域的顶尖能力组合起来。</p></div></li>
          </ol>
        </div>
      </section>

      <section class="join-section">
        <p><span>如果你正在独立构建前沿技术，</span><span>我们想认识你。</span></p>
        <a href="mailto:info@airdb.com?subject=%E5%8A%A0%E5%85%A5%20AIRDB%20Team">申请首批席位 <span aria-hidden="true">→</span></a>
      </section>
    </main>

    <footer>
      <div class="footer-brand">
        <a class="brand brand-footer" href="#top"><strong>AIRDB</strong><span>/</span><em>TEAM</em></a>
        <p>Independent by design.<br />Connected by ambition.</p>
        <p class="footer-parent">AIRDB Team 是 AIRDB 的人才网络，连接集团内独立经营的一人公司。</p>
      </div>
      <div class="footer-links">
        <b>本站</b>
        <a href="#people">成员与席位</a>
        <a href="#capabilities">开放方向</a>
        <a href="mailto:info@airdb.com">联系我们</a>
      </div>
      <div class="footer-links">
        <b>AIRDB 生态</b>
        <a href="https://airdb.com" rel="noopener">airdb.com · 主站</a>
        <a href="https://airdb.group" rel="noopener">airdb.group · 集团</a>
        <a href="https://airdb.fund" rel="noopener">airdb.fund · 基金会</a>
      </div>
      <small>© 2026 AIRDB Team</small>
    </footer>

    <dialog class="member-dialog" aria-labelledby="dialog-name">
      <button class="dialog-close" aria-label="关闭资料">×</button>
      <div class="dialog-portrait portrait p0">
        <span class="dialog-seat-mark" aria-hidden="true">SEAT<br />OPEN</span>
      </div>
      <div class="dialog-copy">
        <span class="dialog-company"></span>
        <h2 class="dialog-name" id="dialog-name"></h2>
        <p class="dialog-role"></p>
        <dl><div><dt>所在地</dt><dd class="dialog-place"></dd></div><div><dt>专长</dt><dd class="dialog-focus"></dd></div><div class="dialog-motto-row" hidden><dt>信条</dt><dd class="dialog-motto"></dd></div></dl>
        <a class="dialog-cta" href="mailto:info@airdb.com"><span class="dialog-cta-label">发起协作</span> <span aria-hidden="true">→</span></a>
      </div>
    </dialog>

    <script define:vars={{ entries, domainLabel }}>
      const filterButtons = document.querySelectorAll('[data-filter]');
      const validFilters = new Set(Array.from(filterButtons, (button) => button.dataset.filter));
      const cards = document.querySelectorAll('.member');
      const total = cards.length;
      const peopleSection = document.querySelector('#people');
      const searchInput = document.querySelector('#member-search');
      const emptyState = document.querySelector('.empty-state');
      const resultCount = document.querySelector('.result-count');
      let activeField = 'all';
      let query = '';

      function updateDirectory() {
        let visibleCount = 0;
        cards.forEach((card) => {
          const fieldMatches = activeField === 'all' || card.dataset.field === activeField;
          const searchMatches = !query || card.dataset.search.includes(query);
          card.hidden = !(fieldMatches && searchMatches);
          if (!card.hidden) visibleCount += 1;
        });
        filterButtons.forEach((button) => {
          const on = button.dataset.filter === activeField;
          button.classList.toggle('active', on);
          button.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
        emptyState.hidden = visibleCount > 0;
        resultCount.textContent = `${visibleCount} / ${total} 项`;
      }

      // Filter and search are independent facets; changing one no longer wipes the other.
      function syncHash() {
        const parts = [];
        if (activeField !== 'all') parts.push(activeField);
        if (query) parts.push('q=' + encodeURIComponent(query));
        const hash = parts.length ? '#people/' + parts.join('/') : '#people';
        history.replaceState(null, '', hash);
      }

      function selectField(field, { scroll = false } = {}) {
        activeField = validFilters.has(field) ? field : 'all';
        updateDirectory();
        syncHash();
        if (scroll) peopleSection?.scrollIntoView({ behavior: 'smooth' });
      }

      function readHash() {
        const match = location.hash.match(/^#people(?:\/(.*))?$/);
        if (!match) return;
        activeField = 'all';
        query = '';
        (match[1] || '').split('/').forEach((part) => {
          if (part.startsWith('q=')) query = decodeURIComponent(part.slice(2)).toLowerCase();
          else if (validFilters.has(part)) activeField = part;
        });
        if (searchInput) searchInput.value = query;
        updateDirectory();
      }

      filterButtons.forEach((button) => button.addEventListener('click', () => selectField(button.dataset.filter)));
      searchInput?.addEventListener('input', (event) => {
        query = event.currentTarget.value.trim().toLowerCase();
        updateDirectory();
        syncHash();
      });
      document.querySelector('[data-reset-directory]')?.addEventListener('click', () => {
        query = '';
        if (searchInput) searchInput.value = '';
        selectField('all');
      });
      document.addEventListener('click', (event) => {
        const jumpTarget = event.target.closest('[data-jump]');
        if (!jumpTarget) return;
        query = '';
        if (searchInput) searchInput.value = '';
        selectField(jumpTarget.dataset.jump, { scroll: true });
      });

      const dialog = document.querySelector('.member-dialog');
      const dialogPortrait = dialog?.querySelector('.dialog-portrait');
      const dialogCta = dialog?.querySelector('.dialog-cta');
      document.querySelectorAll('.member-open').forEach((button) => button.addEventListener('click', () => {
        const item = entries[Number(button.closest('.member').dataset.index)];
        const isFounder = item.kind === 'founder';
        dialog.classList.toggle('dialog-opening', !isFounder);
        dialog.querySelector('.dialog-company').textContent = isFounder ? item.company + ' · FOUNDER' : domainLabel[item.field] + ' · 招募位';
        dialog.querySelector('.dialog-name').textContent = isFounder ? item.name : item.seat;
        dialog.querySelector('.dialog-role').textContent = isFounder ? item.role : item.status;
        dialog.querySelector('.dialog-place').textContent = item.place;
        dialog.querySelector('.dialog-focus').textContent = item.focus;
        const mottoRow = dialog.querySelector('.dialog-motto-row');
        mottoRow.hidden = isFounder ? false : true;
        dialog.querySelector('.dialog-motto').textContent = isFounder ? item.motto : '';
        dialogPortrait.className = isFounder ? 'dialog-portrait portrait p0' : 'dialog-portrait';
        dialogCta.querySelector('.dialog-cta-label').textContent = isFounder ? '发起协作' : '应聘这个席位';
        dialogCta.href = isFounder ? 'mailto:info@airdb.com' : 'mailto:info@airdb.com?subject=' + encodeURIComponent('应聘：' + item.seat);
        dialog.showModal();
      }));
      dialog?.querySelector('.dialog-close')?.addEventListener('click', () => dialog.close());
      dialog?.addEventListener('click', (event) => { if (event.target === dialog) dialog.close(); });

      readHash();
      window.addEventListener('hashchange', readHash);

      const founderCard = document.querySelector('.member-founder');
      if (founderCard && 'IntersectionObserver' in window) {
        const observer = new IntersectionObserver((observed) => {
          if (observed.some((entry) => entry.isIntersecting)) {
            founderCard.classList.add('boot');
            observer.disconnect();
          }
        }, { threshold: 0.35 });
        observer.observe(founderCard);
      } else {
        founderCard?.classList.add('boot');
      }
    </script>
  </body>
</html>
